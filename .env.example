# Email Configuration (for contact form & careers submissions)
# Use Gmail, SendGrid, or any SMTP provider

# Gmail example:
# 1. Enable 2FA on your Google Account
# 2. Generate an App Password at myaccount.google.com/apppasswords
# 3. Use your email as SMTP_USER and App Password as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=noreply@wathiq.digital

# Contact form recipient email (keep hidden, use environment variable)
CONTACT_EMAIL=abo-barhoom@hotmail.com

# Site URL (for SEO and metadata)
NEXT_PUBLIC_SITE_URL=https://wathiq.digital

# Google Analytics 4
# Get your GA4 ID from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
