# ── Email (job applications) ──────────────────────────────
# Copy this file to .env.local and fill in your SMTP details.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your-app-password   # https://myaccount.google.com/apppasswords
#   SMTP_FROM=careers@wathiq.digital
#
# Outlook / Office 365:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_SECURE=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=careers@wathiq.digital
